---
import TranslatorPanel from '../components/TranslatorPanel.jsx';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Traductor IA | Guarani a Espanol">
	<main class="home">
		<TranslatorPanel client:load />

		<nav class="quick-links" aria-label="Accesos rapidos">
			<a href="/comunidad">
				<span aria-hidden="true">H</span>
				Historial
			</a>
			<a href="/comunidad">
				<span aria-hidden="true">S</span>
				Guardados
			</a>
			<a href="/comunidad">
				<span aria-hidden="true">C</span>
				Comunidad
			</a>
		</nav>
	</main>
</Layout>

<style>
	.home {
		width: min(1080px, calc(100% - 32px));
		margin: 0 auto;
		padding: 46px 0 88px;
	}

	:global(.translator) {
		width: 100%;
	}

	:global(.translator-tabs) {
		display: flex;
		justify-content: center;
		gap: 12px;
		margin-bottom: 26px;
	}

	:global(.mode-tab) {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		border: 1px solid rgba(0, 90, 193, 0.18);
		border-radius: 999px;
		padding: 10px 18px;
		background: #ffffff;
		color: var(--primary);
		font-size: 14px;
		font-weight: 700;
		box-shadow: 0 1px 2px rgba(22, 29, 37, 0.08);
		cursor: pointer;
	}

	:global(.mode-tab span) {
		display: grid;
		width: 22px;
		height: 22px;
		place-items: center;
		border-radius: 50%;
		background: var(--primary-container);
		color: var(--primary);
		font-size: 12px;
		font-weight: 800;
	}

	:global(.mode-tab.active) {
		border-color: rgba(0, 90, 193, 0.28);
		background: #ffffff;
		color: var(--primary);
	}

	:global(.language-shell) {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 0;
		border: 1px solid var(--line);
		border-radius: 28px;
		background: var(--soft-container);
		box-shadow:
			0 1px 2px rgba(22, 29, 37, 0.08),
			0 12px 30px rgba(0, 43, 92, 0.06);
		overflow: hidden;
	}

	:global(.language-column) {
		display: grid;
		grid-template-rows: auto minmax(220px, auto) auto;
		min-width: 0;
		background: #ffffff;
	}

	:global(.language-column.result) {
		background: #eef4ff;
	}

	:global(.language-column:first-child) {
		border-right: 1px solid rgba(196, 199, 197, 0.72);
	}

	:global(.language-bar) {
		display: flex;
		align-items: center;
		gap: 8px;
		min-height: 60px;
		padding: 12px 18px 8px;
		border-bottom: 1px solid rgba(196, 199, 197, 0.54);
		overflow-x: auto;
	}

	:global(.chip) {
		flex: 0 0 auto;
		border: 1px solid transparent;
		border-radius: 999px;
		padding: 9px 16px;
		background: transparent;
		color: var(--primary);
		font-size: 13px;
		font-weight: 800;
		line-height: 1;
		cursor: pointer;
	}

	:global(.chip.active) {
		border-color: rgba(0, 90, 193, 0.18);
		background: var(--primary-container);
		color: var(--on-primary-container);
	}

	:global(.language-column textarea) {
		width: 100%;
		min-height: 246px;
		resize: vertical;
		border: 0;
		outline: 0;
		padding: 28px 26px 12px;
		background: transparent;
		color: var(--ink);
		font-size: 24px;
		line-height: 1.45;
	}

	:global(.language-column textarea::placeholder) {
		color: #747b86;
	}

	:global(.result textarea) {
		color: #26323f;
	}

	:global(.panel-footer) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 54px;
		padding: 6px 24px 18px;
		color: #68717d;
		font-size: 12px;
	}

	:global(.result-footer) {
		justify-content: flex-end;
	}

	:global(.icon-button) {
		display: grid;
		width: 36px;
		height: 36px;
		place-items: center;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: #5f6368;
		font-weight: 800;
		cursor: pointer;
	}

	:global(.icon-button:hover) {
		background: rgba(211, 228, 255, 0.7);
	}

	:global(.icon-button:disabled) {
		cursor: default;
		opacity: 0;
	}

	:global(.direction-lock) {
		position: absolute;
		top: 30px;
		left: 50%;
		z-index: 2;
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		border: 1px solid rgba(0, 90, 193, 0.2);
		border-radius: 50%;
		background: #ffffff;
		color: var(--primary);
		font-size: 16px;
		font-weight: 900;
		box-shadow: 0 1px 2px rgba(22, 29, 37, 0.1);
		transform: translate(-50%, -50%);
	}

	:global(.translator-actions) {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 14px;
		margin-top: 26px;
	}

	:global(.translator-actions button) {
		min-width: 132px;
		border: 0;
		border-radius: 999px;
		padding: 13px 28px;
		background: var(--primary);
		color: white;
		font-size: 15px;
		font-weight: 800;
		box-shadow: 0 1px 2px rgba(22, 29, 37, 0.14);
		cursor: pointer;
	}

	:global(.translator-actions button:hover:not(:disabled)) {
		background: #004da5;
	}

	:global(.translator-actions button:disabled) {
		cursor: not-allowed;
		opacity: 0.5;
	}

	:global(.status) {
		margin: 0;
		color: var(--muted);
		font-size: 14px;
	}

	:global(.status.error) {
		color: var(--danger);
	}

	.quick-links {
		display: flex;
		justify-content: center;
		gap: 42px;
		margin-top: 72px;
	}

	.quick-links a {
		display: grid;
		justify-items: center;
		gap: 10px;
		color: var(--muted);
		font-size: 14px;
		font-weight: 600;
		text-decoration: none;
	}

	.quick-links span {
		display: grid;
		width: 46px;
		height: 46px;
		place-items: center;
		border-radius: 50%;
		background: #edf3ff;
		color: var(--primary);
		font-weight: 800;
	}

	.quick-links a:hover {
		color: var(--primary);
	}

	.quick-links a:hover span {
		background: var(--primary-container);
		color: var(--primary);
	}

	@media (max-width: 760px) {
		.home {
			width: min(100% - 18px, 1040px);
			padding-top: 24px;
		}

		:global(.translator-tabs) {
			margin-bottom: 18px;
		}

		:global(.language-shell) {
			grid-template-columns: 1fr;
			border-radius: 28px;
		}

		:global(.language-column:first-child) {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}

		:global(.direction-lock) {
			top: 50%;
			transform: translate(-50%, -50%) rotate(90deg);
		}

		:global(.language-column textarea) {
			min-height: 170px;
			font-size: 20px;
		}

		:global(.translator-actions) {
			align-items: stretch;
			flex-direction: column;
		}

		.quick-links {
			gap: 24px;
			margin-top: 50px;
		}
	}
</style>

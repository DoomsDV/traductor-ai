---
import CommunityTrends from "../components/CommunityTrends.jsx";
import CommunityLoginPanel from "../components/CommunityLoginPanel.jsx";
import Layout from "../layouts/Layout.astro";

const pageTitle = "Comunidad Jopara | Tendencias y Diccionario Guaraní";
const pageDescription =
	"Descubre las palabras mejor votadas del diccionario guaraní online, ejemplos reales y tendencias de la comunidad de traductor IA en Paraguay.";
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonicalURL="/comunidad"
	ogImage="/og/traductor-ia-og.svg"
>
	<main class="community">
		<section class="community-hero" aria-labelledby="community-title">
			<div>
				<p class="eyebrow">Comunidad</p>
				<h1 id="community-title">
					Tendencias y definiciones compartidas.
				</h1>
				<p>
					Explora las palabras con mejor puntaje y revisa ejemplos
					publicados por otros usuarios.
				</p>
			</div>

			<aside class="login-panel" aria-label="Crear definiciones">
				<CommunityLoginPanel client:load />
			</aside>
		</section>

		<section class="trends-section" aria-labelledby="trends-title">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Top 50</p>
					<h2 id="trends-title">Tendencias</h2>
				</div>
			</div>

			<CommunityTrends client:load />
		</section>
	</main>
</Layout>

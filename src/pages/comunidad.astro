---
import CommunityTrends from '../components/CommunityTrends.jsx';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Comunidad | Traductor IA">
	<main class="community">
		<section class="community-hero" aria-labelledby="community-title">
			<div>
				<p class="eyebrow">Comunidad</p>
				<h1 id="community-title">Tendencias y definiciones compartidas.</h1>
				<p>
					Explora las palabras con mejor puntaje y revisa ejemplos publicados por otros
					usuarios.
				</p>
			</div>

			<aside class="login-panel" aria-label="Crear definiciones">
				<h2>Participa en la comunidad</h2>
				<p>Inicia sesion para crear tus propias definiciones y votar las mejores entradas.</p>
				<button type="button" class="google-button">
					<span class="google-icon" aria-hidden="true">G</span>
					Iniciar sesion con Google
				</button>
			</aside>
		</section>

		<section class="trends-section" aria-labelledby="trends-title">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Top 50</p>
					<h2 id="trends-title">Trends</h2>
				</div>
			</div>

			<CommunityTrends client:load />
		</section>
	</main>
</Layout>

<style>
	.community {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 58px 0 96px;
	}

	.community-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 360px;
		gap: 36px;
		align-items: end;
		margin-bottom: 54px;
	}

	.eyebrow {
		margin: 0 0 10px;
		color: var(--accent);
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 760px;
		margin: 0;
		color: var(--ink);
		font-size: clamp(34px, 6vw, 64px);
		line-height: 1;
		letter-spacing: 0;
	}

	.community-hero p:not(.eyebrow),
	.login-panel p {
		color: var(--muted);
		font-size: 17px;
		line-height: 1.6;
	}

	.community-hero p:not(.eyebrow) {
		max-width: 620px;
		margin: 20px 0 0;
	}

	.login-panel {
		padding: 22px;
		border: 1px solid rgba(32, 33, 36, 0.09);
		border-radius: 8px;
		background: var(--surface-strong);
		box-shadow: 0 18px 55px rgba(61, 48, 25, 0.1);
	}

	.login-panel h2 {
		margin: 0;
		font-size: 21px;
		line-height: 1.25;
	}

	.login-panel p {
		margin: 12px 0 18px;
		font-size: 15px;
	}

	.google-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		width: 100%;
		border: 1px solid var(--line);
		border-radius: 8px;
		padding: 12px 14px;
		background: #ffffff;
		color: var(--ink);
		font-weight: 800;
		cursor: pointer;
	}

	.google-button:hover {
		border-color: #bbb2a2;
		background: #fbfaf7;
	}

	.google-icon {
		display: grid;
		width: 24px;
		height: 24px;
		place-items: center;
		border-radius: 50%;
		background: #f2f4f7;
		color: #4285f4;
		font-weight: 900;
	}

	.trends-section {
		padding-top: 26px;
		border-top: 1px solid rgba(32, 33, 36, 0.1);
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		margin-bottom: 18px;
	}

	.section-heading h2 {
		margin: 0;
		font-size: 30px;
		line-height: 1.1;
	}

	:global(.trend-state) {
		margin: 0;
		padding: 26px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface-strong);
		color: var(--muted);
	}

	:global(.trend-error) {
		color: var(--danger);
	}

	:global(.trend-list) {
		display: grid;
		gap: 12px;
	}

	:global(.trend-card) {
		display: grid;
		grid-template-columns: 74px minmax(0, 1fr);
		gap: 18px;
		padding: 18px;
		border: 1px solid rgba(32, 33, 36, 0.08);
		border-radius: 8px;
		background: rgba(255, 253, 248, 0.88);
	}

	:global(.trend-score) {
		display: grid;
		place-items: center;
		align-self: start;
		min-height: 74px;
		border-radius: 8px;
		background: var(--accent-soft);
		color: var(--accent-dark);
	}

	:global(.trend-score strong) {
		font-size: 24px;
		line-height: 1;
	}

	:global(.trend-score span) {
		color: var(--muted);
		font-size: 12px;
		font-weight: 800;
		text-transform: uppercase;
	}

	:global(.trend-content) {
		min-width: 0;
	}

	:global(.trend-heading) {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 8px;
	}

	:global(.trend-heading h2) {
		margin: 0;
		font-size: 23px;
		line-height: 1.2;
	}

	:global(.trend-heading span) {
		color: var(--muted);
		font-size: 13px;
		font-weight: 750;
	}

	:global(.trend-content p) {
		margin: 0;
		color: var(--ink);
		font-size: 16px;
		line-height: 1.55;
	}

	:global(.trend-content q) {
		display: block;
		margin-top: 10px;
		color: var(--muted);
		font-size: 15px;
		line-height: 1.5;
	}

	:global(.trend-votes) {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 14px;
	}

	:global(.trend-votes span) {
		padding: 5px 8px;
		border-radius: 999px;
		background: #f0ece4;
		color: var(--muted);
		font-size: 12px;
		font-weight: 800;
	}

	@media (max-width: 840px) {
		.community-hero {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}

	@media (max-width: 620px) {
		.community {
			padding-top: 38px;
		}

		:global(.trend-card) {
			grid-template-columns: 1fr;
		}

		:global(.trend-score) {
			display: flex;
			justify-content: flex-start;
			gap: 6px;
			width: fit-content;
			min-height: auto;
			padding: 10px 12px;
		}

		:global(.trend-heading) {
			align-items: flex-start;
			flex-direction: column;
			gap: 4px;
		}
	}
</style>

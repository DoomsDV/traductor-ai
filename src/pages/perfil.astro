---
import Layout from '../layouts/Layout.astro';
import MyDefinitionsPanel from '../components/MyDefinitionsPanel.jsx';

const pageTitle = 'Mi Perfil | Aportes en Comunidad';
const pageDescription = 'Consulta todas tus definiciones publicadas y su estado en la comunidad.';
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonicalURL="/perfil"
	ogImage="/og/traductor-ia-og.svg"
>
	<main class="community">
		<section class="community-hero" aria-labelledby="profile-title">
			<div>
				<p class="eyebrow">MI PERFIL</p>
				<h1 id="profile-title">Mis definiciones.</h1>
				<p>Un historial completo de tus aportes a la comunidad, incluyendo el estado de cada entrada.</p>
			</div>
		</section>

		<section class="trends-section" aria-labelledby="profile-definitions">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Aportes</p>
					<h2 id="profile-definitions">Historial</h2>
				</div>
			</div>

			<MyDefinitionsPanel client:load />
		</section>
	</main>
</Layout>

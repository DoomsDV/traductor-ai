---
interface Props {
	title?: string;
}

const { title = 'Traductor IA' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/" aria-label="Traductor IA">
				<span class="brand-mark">A</span>
				<span>Traductor IA</span>
			</a>
			<nav class="site-nav" aria-label="Principal">
				<a href="/">Traducir</a>
				<a href="/comunidad">Comunidad</a>
			</nav>
		</header>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--bg: #f7f9ff;
		--surface: #f7f9ff;
		--surface-strong: #ffffff;
		--ink: #1a1c1e;
		--muted: #5d6470;
		--line: #c4c7c5;
		--primary: #005ac1;
		--primary-container: #d3e4ff;
		--on-primary-container: #001c3b;
		--soft-container: #eef4ff;
		--blue: var(--primary);
		--accent: var(--primary);
		--accent-dark: #003f88;
		--accent-soft: var(--primary-container);
		--gold: #c48a28;
		--danger: #a44035;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background:
			radial-gradient(circle at 50% -120px, rgba(211, 228, 255, 0.9), transparent 360px),
			var(--bg);
		color: var(--ink);
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}

	button,
	textarea,
	input {
		font: inherit;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		width: min(1120px, calc(100% - 28px));
		margin: 0 auto;
		padding: 20px 0 14px;
		background: rgba(247, 249, 255, 0.84);
		backdrop-filter: blur(10px);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--ink);
		font-size: 20px;
		font-weight: 500;
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		width: 30px;
		height: 30px;
		place-items: center;
		border-radius: 6px;
		background: var(--primary-container);
		color: var(--on-primary-container);
		font-size: 16px;
		font-weight: 800;
	}

	.site-nav {
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.site-nav a {
		padding: 9px 12px;
		border-radius: 999px;
		color: var(--muted);
		font-size: 14px;
		font-weight: 500;
		text-decoration: none;
	}

	.site-nav a:hover {
		background: #f1f3f4;
		color: #3c4043;
	}

	@media (max-width: 620px) {
		.site-header {
			align-items: flex-start;
			flex-direction: column;
			gap: 12px;
		}

		.site-nav {
			width: 100%;
		}

		.site-nav a {
			flex: 1;
			text-align: center;
		}
	}
</style>
